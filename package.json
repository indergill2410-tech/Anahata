{
  "name": "anahata",
  "version": "1.0.0",
  "description": "AI-powered biometric meditation with adaptive Indian classical music",
  "private": true,
  "scripts": {
    "dev":         "concurrently \"npm run server\" \"npm run client\"",
    "server":      "cd server && nodemon index.js",
    "client":      "cd client && npm run dev",
    "build":       "cd client && npm install && npm run build",
    "start":       "node server/index.js",
    "test":        "jest --forceExit",
    "test:watch":  "jest --watch",
    "test:coverage": "jest --coverage --forceExit",
    "install:all": "npm install && cd client && npm install"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.43.0",
    "bcryptjs":             "^2.4.3",
    "cors":                 "^2.8.5",
    "dotenv":               "^16.4.5",
    "express":              "^4.19.2",
    "express-rate-limit":   "^7.2.0",
    "helmet":               "^7.1.0",
    "jsonwebtoken":         "^9.0.2",
    "morgan":               "^1.10.0",
    "ws":                   "^8.17.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "jest":         "^29.7.0",
    "nodemon":      "^3.1.0",
    "supertest":    "^7.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
