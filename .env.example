# Server
PORT=3000
NODE_ENV=development

# AI Music API — choose one
AI_MUSIC_API_KEY=your_api_key_here
AI_MUSIC_API_URL=https://api.loudly.com/v1/generate
# Alternative: https://generativelanguage.googleapis.com/v1beta/models/lyria-realtime (Lyria)

# Supabase
DATABASE_URL=your_supabase_connection_pooler_url
DIRECT_URL=your_supabase_direct_url
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# JWT
JWT_SECRET=your_super_secret_jwt_key_min_32_chars
