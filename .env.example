# Anahata — Environment Variables
# Copy this file to .env and fill in your real values.
# NEVER commit .env to git.

# ─── Server ──────────────────────────────────────────────
NODE_ENV=development
PORT=3001

# JWT — generate a strong secret (run once):
# node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-me-to-a-long-random-secret-min-32-chars

# ─── PocketBase ───────────────────────────────────────────
# Local dev: http://localhost:8090
# Production: https://your-pocketbase-instance.fly.dev  (or Railway, etc.)
POCKETBASE_URL=http://localhost:8090

# PocketBase admin credentials (used only by pb-migrations/setup-collections.js)
POCKETBASE_ADMIN_EMAIL=admin@example.com
POCKETBASE_ADMIN_PASSWORD=change-me-strong-password

# ─── Email / SMTP ─────────────────────────────────────────
# REQUIRED for signup verification & password-reset emails to actually send.
# Without these, PocketBase accepts requestVerification() but never delivers
# the email. Read by pb-migrations/setup-collections.js, which writes them
# into PocketBase's mail settings. Re-run `npm run setup:db` after changing.
#
# Example (Gmail app password / SendGrid / Mailgun / Postmark all work):
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
# Address/name shown as the sender. Defaults to SMTP_USERNAME / "Anahata".
SMTP_SENDER_ADDRESS=no-reply@anahata.app
SMTP_SENDER_NAME=Anahata
# Optional: implicit TLS (auto-true for port 465, false for 587/25).
# SMTP_TLS=true
# Optional: PLAIN | LOGIN | CRAM-MD5 (blank = auto).
# SMTP_AUTH_METHOD=
# Public URL used to build links inside verification emails.
APP_URL=http://localhost:5173

# ─── Vite client (prefix VITE_ exposes to browser) ────────
VITE_WS_URL=ws://localhost:3001/ws

# ─── Observability (optional) ─────────────────────────────
SENTRY_DSN=

# ─── Production overrides (set in Render / Docker) ────────
# POCKETBASE_URL=https://anahata-pocketbase.fly.dev
# VITE_WS_URL=wss://your-app.onrender.com/ws
