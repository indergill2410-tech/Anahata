# Anahata — Environment Variables
# Copy this file to .env and fill in your real values.
# NEVER commit .env to git.

# ─── Server ──────────────────────────────────────────────
NODE_ENV=development
PORT=3001

# JWT — generate a strong secret (run once):
# node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-me-to-a-long-random-secret-min-32-chars

# ─── Supabase ─────────────────────────────────────────────
# Get these from: supabase.com > your project > Settings > API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-public-key
SUPABASE_SERVICE_KEY=your-service-role-secret-key

# ─── Vite client (prefix VITE_ exposes to browser) ────────
VITE_WS_URL=ws://localhost:3001/ws

# ─── Production overrides (set in Render / Docker) ────────
# SUPABASE_URL=https://your-project-ref.supabase.co
# VITE_WS_URL=wss://your-app.onrender.com/ws
