# Anahata — Environment Variables
# Copy this file to .env and fill in your real values.
# NEVER commit .env to git.

# ─── Server ──────────────────────────────────────────────
NODE_ENV=development
PORT=3001

# JWT — generate a strong secret (run once):
# node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-me-to-a-long-random-secret-min-32-chars

# ─── PocketBase ───────────────────────────────────────────
# Local dev: http://localhost:8090
# Production: https://your-pocketbase-instance.fly.dev  (or Railway, etc.)
POCKETBASE_URL=http://localhost:8090

# PocketBase admin credentials (used only by pb-migrations/setup-collections.js)
POCKETBASE_ADMIN_EMAIL=admin@example.com
POCKETBASE_ADMIN_PASSWORD=change-me-strong-password

# ─── Vite client (prefix VITE_ exposes to browser) ────────
VITE_WS_URL=ws://localhost:3001/ws

# ─── Observability (optional) ─────────────────────────────
SENTRY_DSN=

# ─── Production overrides (set in Render / Docker) ────────
# POCKETBASE_URL=https://anahata-pocketbase.fly.dev
# VITE_WS_URL=wss://your-app.onrender.com/ws
